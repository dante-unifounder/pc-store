# ── Google AI (required) ─────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here

# ── Google Sheets inventory (optional) ───────────────────────────────────────
# If set, the PCBot tool reads stock live from your Google Sheet.
# If NOT set, falls back to data/inventory.json (great for local dev).
#
# Sheet layout (row 1 = headers, data from row 2):
#   A: id | B: category | C: name | D: brand | E: price | F: stock | G: description
#
# Get a Google Cloud API key with Sheets API enabled:
#   https://console.cloud.google.com/apis/credentials
#
# Copy the Sheet ID from the URL:
#   https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
#
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEETS_API_KEY=your_google_cloud_api_key_here